# Prism demo environment — copy to `.env` and fill the two secrets.
#   cp .env.example .env
#   openssl rand -hex 32   # run twice; paste into SECRET_KEY and UTILS_SECRET

# --- you must set these two ---
SECRET_KEY=
UTILS_SECRET=

# --- access ---
# URL must match how you open the app in your browser (host + HOST_PORT below).
URL=http://localhost:3939
HOST_PORT=3939
# Plain HTTP for local evaluation (no TLS / reverse proxy in this bundle).
FORCE_HTTPS=false

# --- runtime (leave as-is) ---
NODE_ENV=production
DATABASE_URL=postgres://outline:outline@postgres:5432/outline
PGSSLMODE=disable
REDIS_URL=redis://redis:6379
FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data

# --- optional: enable email sign-in (needed only to log in AGAIN after logout) ---
# Without these, the first "Create workspace" still logs you in fine.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@prism.local
